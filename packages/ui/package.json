{
	"name": "ui",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && bun run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:browser": "vitest run --project browser",
		"test:browser:racing": "vitest run --project browser src/lib/racing/engine/three-renderer.browser.test.ts",
		"test:logic:racing:controls": "bun test src/lib/racing/engine/input.test.ts src/lib/racing/engine/physics/index.test.ts src/lib/racing/engine/RacingEngine.test.ts",
		"test:logic:racing:engine": "bun test src/lib/racing/engine/RacingEngine.test.ts src/lib/racing/engine/tracks/ribbon-geometry.test.ts",
		"test:logic:racing:physics": "bun test src/lib/racing/engine/physics/contributors.test.ts src/lib/racing/engine/physics/index.test.ts src/lib/racing/engine/physics/module-edge-cases.test.ts src/lib/racing/engine/physics/tire-dataset.test.ts src/lib/racing/engine/physics/contact-patch.test.ts src/lib/racing/engine/validation/gt3-physics-bench.test.ts",
		"test:logic:racing": "bun run test:logic:racing:engine && bun run test:logic:racing:physics",
		"test:visual:racing": "vitest run --project browser src/lib/racing/engine/three-renderer.browser.test.ts",
		"test:logic:rts:engine": "bun test src/lib/rts/engine/RtsEngine.test.ts src/lib/rts/engine/pathfinding.test.ts src/lib/rts/engine/iso.test.ts",
		"test:logic:rts:ai": "bun test src/lib/rts/engine/ai.test.ts",
		"test:logic:rts:feedback": "bun test src/lib/rts/engine/fx/feedback.test.ts src/lib/rts/engine/audio-bus.test.ts",
		"test:logic:rts:fog": "bun test src/lib/rts/engine/systems/fog-of-war.test.ts",
		"test:logic:rts:projectiles": "bun test src/lib/rts/engine/systems/projectile-arc.test.ts",
		"test:logic:rts:atlas": "bun test src/lib/rts/engine/sprites/atlas.test.ts",
		"test:logic:rts": "bun run test:logic:rts:engine && bun run test:logic:rts:ai && bun run test:logic:rts:feedback && bun run test:logic:rts:fog && bun run test:logic:rts:projectiles && bun run test:logic:rts:atlas",
		"test:visual:rts": "bun run test:logic:rts:atlas",
		"test": "bun run test:browser && bun run test:logic:racing && bun run test:logic:rts",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"src/lib",
		"!src/lib/**/*.test.*",
		"!src/lib/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./source": {
			"types": "./src/lib/index.ts",
			"svelte": "./src/lib/index.ts",
			"default": "./src/lib/index.ts"
		},
		"./source/chat/headless": {
			"types": "./src/lib/chat/headless.ts",
			"svelte": "./src/lib/chat/headless.ts",
			"default": "./src/lib/chat/headless.ts"
		},
		"./styles/*": "./src/lib/styles/*",
		"./source/storyboard": {
			"types": "./src/lib/storyboard/index.ts",
			"svelte": "./src/lib/storyboard/index.ts",
			"default": "./src/lib/storyboard/index.ts"
		},
		"./source/marketing": {
			"types": "./src/lib/marketing/index.ts",
			"svelte": "./src/lib/marketing/index.ts",
			"default": "./src/lib/marketing/index.ts"
		},
		"./source/agent-registry": {
			"types": "./src/lib/agent-registry/index.ts",
			"svelte": "./src/lib/agent-registry/index.ts",
			"default": "./src/lib/agent-registry/index.ts"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@chromatic-com/storybook": "^5.1.1",
		"@storybook/addon-a11y": "^10.3.4",
		"@storybook/addon-docs": "^10.3.4",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.4",
		"@storybook/sveltekit": "^10.3.4",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@types/sanitize-html": "^2.16.1",
		"@types/three": "0.160.0",
		"@vitest/browser-playwright": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"mdsvex": "^0.12.6",
		"publint": "^0.3.17",
		"storybook": "^10.3.4",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.1"
	},
	"keywords": [
		"svelte"
	],
	"dependencies": {
		"@lucide/svelte": "^1.7.0",
		"@pixi/sound": "^6.0.1",
		"@pixi/tilemap": "^5.0.2",
		"bits-ui": "^2.17.2",
		"clsx": "^2.1.1",
		"fabric": "^7.3.1",
		"jolt-physics": "0.31.0",
		"jszip": "^3.10.1",
		"marked": "^18.0.0",
		"paneforge": "^1.0.2",
		"pixi.js": "^8.18.1",
		"sanitize-html": "^2.17.3",
		"svelte-dnd-action": "^0.9.69",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"three": "0.160.0",
		"tw-animate-css": "^1.4.0"
	}
}
