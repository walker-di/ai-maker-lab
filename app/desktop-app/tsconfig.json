{
	"compilerOptions": {
		"allowJs": true,
		"allowImportingTsExtensions": true,
		"checkJs": true,
		"baseUrl": ".",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "ES2022",
		"types": ["vite/client"],
		"paths": {
			"$lib/*": ["./src/lib/*"],
			"$src/*": ["./src/*"]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.js",
		"src/**/*.d.ts",
		"src/**/*.svelte",
		".storybook/**/*.ts",
		"playwright.config.ts",
		"vite.config.ts",
		"vitest.shims.d.ts"
	]
}
