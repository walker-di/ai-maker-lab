{
	"name": "desktop-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"dependencies": {
		"@ai-maker-lab/domain": "workspace:*",
		"@ai-maker-lab/ui": "workspace:*"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --emit-ts-declarations && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test",
		"test": "npm run test:e2e",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.0.2",
		"@inlang/paraglide-js": "^2.10.0",
		"@playwright/test": "^1.58.2",
		"@storybook/addon-a11y": "^10.3.1",
		"@storybook/addon-docs": "^10.3.1",
		"@storybook/addon-svelte-csf": "^5.0.12",
		"@storybook/addon-vitest": "^10.3.1",
		"@storybook/sveltekit": "^10.3.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"mdsvex": "^0.12.6",
		"playwright": "^1.58.2",
		"storybook": "^10.3.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.0"
	}
}
