{
	"name": "desktop-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"build:web": "vite build",
		"start": "bun run build:web && electrobun dev",
		"dev": "bun run dev:web",
		"dev:web": "vite dev --port 5173",
		"dev:browser": "bun run dev:web",
		"dev:app": "bun run build:web && electrobun dev --watch",
		"dev:desktop": "bun run dev:app",
		"dev:app:hmr": "concurrently \"bun run dev:web\" \"bun run start\"",
		"dev:desktop:hmr": "bun run dev:app:hmr",
		"build": "bun run build:web && electrobun build",
		"build:canary": "bun run build:web && electrobun build --env=canary",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test",
		"test": "bun run test:e2e",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@ai-sdk/svelte": "^4.0.161",
		"@surrealdb/node": "^3.0.3",
		"@surrealdb/node-darwin-arm64": "1.0.0-beta.3",
		"ai": "^6.0.161",
		"domain": "workspace:*",
		"electrobun": "^1.16.0",
		"ui": "workspace:*"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.1",
		"@inlang/paraglide-js": "^2.10.0",
		"@playwright/test": "^1.58.2",
		"@storybook/addon-a11y": "^10.3.4",
		"@storybook/addon-docs": "^10.3.4",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.4",
		"@storybook/sveltekit": "^10.3.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@types/three": "^0.183.1",
		"@vitest/browser-playwright": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"concurrently": "^9.2.1",
		"mdsvex": "^0.12.6",
		"playwright": "^1.59.1",
		"storybook": "^10.3.4",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.2"
	}
}
