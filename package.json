{
  "name": "ai-maker-lab",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "app/desktop-app",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd app/desktop-app dev",
    "build": "bun run --cwd app/desktop-app build",
    "check": "bun run --cwd app/desktop-app check",
    "storybook": "bun run --cwd app/desktop-app storybook",
    "postinstall": "bun run --cwd app/desktop-app prepare"
  }
}
